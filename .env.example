# ============ REQUIRED ============
# Database (required for all apps)
DATABASE_URL="postgresql://user:password@localhost:5432/dbname"
DIRECT_URL="postgresql://user:password@localhost:5432/dbname"

# Admin panel auth (required for admin app, min 32 chars)
JWT_SECRET="your-secure-random-secret-min-32-chars"

# ============ OPTIONAL ============
# Public site URL (for JSON-LD, sitemaps)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Worker
CRON_INTERVAL_MS=3600000
CRON_SECRET=your-cron-secret
LOG_LEVEL=info

# AI (OpenAI) - omit for placeholder/fallback behavior
OPENAI_API_KEY=sk-proj-your-key-here
OPENAI_MODEL=gpt-4o-mini

# SSL (dev only - corporate proxies) - NEVER use in production
NODE_TLS_REJECT_UNAUTHORIZED=0
