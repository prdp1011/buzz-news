# ============ REQUIRED ============
# Database (required for all apps)
#
# --- Local Postgres ---
# DATABASE_URL="postgresql://user:password@localhost:5432/dbname"
# DIRECT_URL="postgresql://user:password@localhost:5432/dbname"
#
# --- Supabase (recommended split for Prisma) ---
# Dashboard: Project Settings → Database → Connection string
#
# DIRECT_URL = "Direct connection" URI (host db.<project-ref>.supabase.co:5432).
#   Use user "postgres" + your database password. Prisma migrate/db push use this.
#
# DATABASE_URL = "Transaction pooler" or "Session pooler" URI from the same page.
#   Pooler username is often postgres.<project-ref> (not plain "postgres"), or copy exactly.
#   Append query params if shown, e.g. ?pgbouncer=true
#
# If you see: FATAL: Tenant or user not found — wrong pooler user/host, or use Direct URI
# for BOTH vars temporarily so `pnpm db:push` works, then switch DATABASE_URL to pooler for the app.
#
DATABASE_URL="postgresql://user:password@localhost:5432/dbname"
DIRECT_URL="postgresql://user:password@localhost:5432/dbname"

# Admin panel auth (required for admin app, min 32 chars)
JWT_SECRET="your-secure-random-secret-min-32-chars"

# ============ OPTIONAL ============
# Public site URL (for JSON-LD, sitemaps)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Worker
CRON_INTERVAL_MS=3600000
CRON_SECRET=your-cron-secret
LOG_LEVEL=info

# AI (OpenAI) - omit for placeholder/fallback behavior
OPENAI_API_KEY=sk-proj-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Cloudinary (for admin cover image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# SSL (dev only - corporate proxies) - NEVER use in production.
# REMOVE from Vercel env vars - it weakens TLS and causes build warnings.
NODE_TLS_REJECT_UNAUTHORIZED=0
