// Buzz News Platform - Database Schema
// PostgreSQL with Prisma ORM

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============ CORE MODELS ============

model Category {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  color       String?  // Hex color for UI
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  posts Post[]
}

enum SourceType {
  RSS
  SOCIAL
  SCRAPER
}

model Source {
  id          String     @id @default(cuid())
  name        String
  url         String
  type        SourceType @default(RSS)
  feedUrl     String     @unique // RSS feed URL, scraper URL, or API endpoint
  config      String?    @db.Text // JSON config for social/scraper (API keys, selectors)
  favicon     String?
  isActive    Boolean    @default(true)
  lastFetched DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  posts Post[]

  @@index([type])
  @@index([isActive])
}

enum PostStatus {
  DRAFT
  PENDING_APPROVAL
  PUBLISHED
  REJECTED
  ARCHIVED
}

model Post {
  id              String     @id @default(cuid())
  slug            String     @unique
  title           String
  seoTitle        String?    // AI-generated SEO title
  summary         String?    @db.Text // AI-generated summary
  content         String     @db.Text
  rawContent      String?    @db.Text // Original content before AI rewrite
  coverImage      String?
  status          PostStatus @default(DRAFT)
  publishedAt     DateTime?
  viewCount       Int        @default(0)
  trendingScore   Float      @default(0) // For trending algorithm
  metaDescription String?    @db.Text
  canonicalUrl    String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  sourceId   String
  source     Source   @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  tags     PostTag[]
  analytics PostAnalytics[]

  @@index([status])
  @@index([categoryId])
  @@index([createdAt])
  @@index([publishedAt])
}

model Tag {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  createdAt DateTime @default(now())

  posts PostTag[]
}

model PostTag {
  postId String
  tagId  String
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
}

// ============ ANALYTICS ============

model PostAnalytics {
  id        String   @id @default(cuid())
  postId    String
  date      DateTime @db.Date
  views     Int      @default(0)
  shares    Int      @default(0)
  avgTime   Int      @default(0) // Average read time in seconds
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, date])
  @@index([postId])
  @@index([date])
}

// ============ SOCIAL POSTS (Instagram, Facebook, YouTube) ============

enum SocialPlatform {
  INSTAGRAM
  FACEBOOK
  YOUTUBE
}

model SocialPost {
  id          String         @id @default(cuid())
  platform    SocialPlatform
  title       String
  content     String?        @db.Text
  imageUrl    String?
  videoUrl    String?        // For YouTube
  publishedAt DateTime?
  status      PostStatus     @default(DRAFT)
  externalUrl String?        // Link to post on platform
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([platform])
  @@index([status])
  @@index([publishedAt])
}

// ============ ADMIN / AUTH ============

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  passwordHash String
  name      String?
  role      String   @default("editor")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============ CONTENT DEDUPLICATION ============

model ContentHash {
  id        String   @id @default(cuid())
  hash      String   @unique // SHA-256 of normalized content for dedup
  sourceId  String
  postId    String?  // Link to post if published
  createdAt DateTime @default(now())

  @@index([hash])
  @@index([sourceId])
}

// ============ QUIZ (public web app) ============

model Quiz {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?  @db.Text
  emoji       String?
  topicSlug   String
  topicLabel  String
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  questions QuizQuestion[]

  @@index([published, topicSlug])
}

model QuizQuestion {
  id     String @id @default(cuid())
  quizId String
  quiz   Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)
  order  Int
  text   String @db.Text

  options QuizOption[]

  @@index([quizId, order])
}

model QuizOption {
  id         String       @id @default(cuid())
  questionId String
  question   QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  order      Int
  text       String
  isCorrect  Boolean      @default(false)

  @@index([questionId, order])
}
