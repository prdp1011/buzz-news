{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "**/.env.*local"
  ],
  "globalEnv": [
    "DATABASE_URL",
    "DIRECT_URL",
    "JWT_SECRET",
    "NEXT_PUBLIC_SITE_URL",
    "OPENAI_API_KEY",
    "OPENAI_MODEL"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**"
      ],
      "env": [
        "DATABASE_URL",
        "DIRECT_URL",
        "JWT_SECRET",
        "NEXT_PUBLIC_SITE_URL",
        "OPENAI_API_KEY",
        "OPENAI_MODEL"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": [
        "^build"
      ]
    }
  },
  "globalPassThroughEnv": [
    "DATABASE_URL",
    "DIRECT_URL",
    "JWT_SECRET",
    "NEXT_PUBLIC_SITE_URL",
    "OPENAI_API_KEY",
    "OPENAI_MODEL"
  ]
}