{
  "name": "buzz-news-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "pnpm --filter web dev",
    "dev:admin": "pnpm --filter admin dev",
    "dev:worker": "pnpm --filter worker dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:generate": "pnpm --filter database exec prisma generate",
    "db:push": "pnpm --filter database exec prisma db push",
    "db:migrate": "pnpm --filter database exec prisma migrate dev",
    "db:seed": "pnpm --filter database exec tsx prisma/seed.ts",
    "db:studio": "pnpm --filter database exec prisma studio",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "build:web": "turbo run build --filter=web",
    "build:admin": "turbo run build --filter=admin",
    "build:vercel": "turbo run build --filter=${BUILD_APP:-web}"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@9.14.2",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "@jridgewell/gen-mapping": "0.3.5"
    }
  }
}